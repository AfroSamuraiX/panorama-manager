{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [
          {
            "breaking": true,
            "release": "minor"
          },
          {
            "type": "feat",
            "release": "minor"
          },
          {
            "type": "fix",
            "release": "patch"
          },
          {
            "type": "perf",
            "release": "patch"
          },
          {
            "type": "revert",
            "release": "patch"
          }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "assets": [
          "dist/pctl-v*-linux-x86_64.tar.gz",
          "dist/pctl-v*-linux-x86_64.sha256",
          "dist/panorama-gui-v*-linux-x86_64.tar.gz",
          "dist/panorama-gui-v*-linux-x86_64.sha256"
        ]
      }
    ]
  ]
}